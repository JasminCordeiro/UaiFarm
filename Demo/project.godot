; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Uai Farm - Demo"
run/main_scene="res://scenes/RatingScreen.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/autoload/game_state.gd"
ClickRipple="*res://scripts/autoload/click_ripple.gd"
AudioSettings="*res://scripts/autoload/audio_settings.gd"
Sfx="*res://scripts/autoload/sfx.gd"
Music="*res://scripts/autoload/music.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=false
window/stretch/mode="canvas_items"

[gui]

theme/custom="res://theme/menu_theme.tres"

